# انسخ هذا الملف إلى .env وعدّل القيم حسب بيئتك
# Copy this file to .env and set your values

# ——— الواجهة (Frontend) ———
# عنوان الـ Backend (اختياري): اتركه فارغاً على Vercel إذا رفعت فرونت اند فقط — يفتح واتساب دون حفظ في قاعدة
VITE_API_URL=http://localhost:3001
# رقم واتساب للحجز — يُستخدم مع زر «تواصل معنا لتأكيد حجزك» (بدون + أو مسافات)
VITE_WHATSAPP_NUMBER=9647501001318

# ——— الخادم (Backend) ———
# منفذ خادم الـ Backend
PORT=3001
# عنوان الواجهة عند النشر (لـ CORS)، مثال: https://yourdomain.com
FRONTEND_URL=

# بيئة التشغيل: development | production
NODE_ENV=development

# ——— MongoDB (اختياري) ———
# إن وُجد، تُحفظ الحجوزات ورسائل التواصل في MongoDB بدل ملفات JSON
# من Atlas: Cluster → Connect → Connect your application → نسخ الرابط
# مثال: mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/dbname?retryWrites=true&w=majority
MONGODB_URI=
